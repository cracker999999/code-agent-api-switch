<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:APISwitch.Models;assembly=Core"
        xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
        x:Class="APISwitch.UI.MainWindow"
        Title="APISwitch"
        Icon="/Assets/app-preview.png"
        Width="884"
        Height="600"
        MinWidth="720"
        MinHeight="460"
        WindowStartupLocation="CenterScreen">
  <Window.Styles>
    <Style Selector="Button.tab">
      <Setter Property="Width" Value="120" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.provider-card">
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.provider-card.active">
      <Setter Property="BorderBrush" Value="#2563EB" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Button.link-button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="Foreground" Value="#2563EB" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.action-btn">
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="Height" Value="30" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.header-action">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#D1D5DB" />
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.plus-action">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#D1D5DB" />
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid Margin="16" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="CodexTabButton" Classes="tab" Click="CodexTabButton_Click" Content="Codex" />
        <Button x:Name="ClaudeTabButton" Classes="tab" Click="ClaudeTabButton_Click" Content="Claude Code" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button x:Name="SessionManagerButton" Classes="header-action" Click="SessionManagerButton_Click" Content="会话管理" />
        <Button x:Name="OpenConfigDirectoryButton" Classes="header-action" Click="OpenConfigDirectoryButton_Click" Content="打开配置目录" />
        <Button x:Name="AddProviderButton" Classes="plus-action" Click="AddProviderButton_Click">
          <Grid Width="14" Height="14">
            <Border Width="14"
                    Height="2"
                    Background="#111827"
                    CornerRadius="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            <Border Width="2"
                    Height="14"
                    Background="#111827"
                    CornerRadius="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
          </Grid>
        </Button>
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
      <ItemsControl x:Name="ProvidersItemsControl">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="models:Provider">
            <Border Classes="provider-card"
                    Classes.active="{Binding IsActive}"
                    PointerPressed="ProviderCard_PointerPressed">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                      <shapes:Ellipse Fill="#22C55E" IsVisible="{Binding IsTestSuccess}" />
                      <shapes:Ellipse Fill="#EF4444" IsVisible="{Binding IsTestFailed}" />
                    </Grid>
                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="{Binding Remark}"
                               Margin="8,0,0,0"
                               Foreground="#9CA3AF"
                               FontSize="11"
                               VerticalAlignment="Center" />
                  </StackPanel>
                  <Button Classes="link-button" Click="BaseUrlButton_Click" Content="{Binding BaseUrl}" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                  <Button Classes="action-btn"
                          Click="ActivateProviderButton_Click"
                          Content="{Binding ActivateButtonText}"
                          IsEnabled="{Binding !IsActive}" />
                  <Button Classes="action-btn" Click="TestProviderButton_Click" Content="测试" />
                  <Button Classes="action-btn" Click="EditProviderButton_Click" Content="编辑" />
                  <Button Classes="action-btn" Click="DeleteProviderButton_Click" Content="删除" />
                  <Button Classes="action-btn" Click="MoveProviderUpButton_Click" Content="↑" IsEnabled="{Binding CanMoveUp}" />
                  <Button Classes="action-btn" Click="MoveProviderDownButton_Click" Content="↓" IsEnabled="{Binding CanMoveDown}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Window>
