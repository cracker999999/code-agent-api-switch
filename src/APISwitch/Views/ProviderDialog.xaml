<Window x:Class="APISwitch.Views.ProviderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="供应商"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Name" FontWeight="SemiBold" />
        <TextBox x:Name="NameTextBox" Grid.Row="1" Margin="0,8,0,14" Height="32" />

        <TextBlock Grid.Row="2" Text="BaseUrl" FontWeight="SemiBold" />
        <TextBox x:Name="BaseUrlTextBox" Grid.Row="3" Margin="0,8,0,14" Height="32" />

        <TextBlock Grid.Row="4" Text="ApiKey" FontWeight="SemiBold" />
        <TextBox x:Name="ApiKeyTextBox" Grid.Row="5" Margin="0,8,0,0" Height="32" />

        <StackPanel Grid.Row="6"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="88" Height="32" Margin="0,0,8,0" IsDefault="True" Click="ConfirmButton_Click">确认</Button>
            <Button Width="88" Height="32" IsCancel="True" Click="CancelButton_Click">取消</Button>
        </StackPanel>
    </Grid>
</Window>
