<Window x:Class="APISwitch.Views.ProviderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="供应商"
        Width="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="名称" FontWeight="SemiBold" />
        <TextBox x:Name="NameTextBox" Grid.Row="1" Margin="0,8,0,14" Height="32" VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="2" Text="BaseUrl" FontWeight="SemiBold" />
        <TextBox x:Name="BaseUrlTextBox" Grid.Row="3" Margin="0,8,0,14" Height="32" VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="4" Text="ApiKey" FontWeight="SemiBold" />
        <TextBox x:Name="ApiKeyTextBox" Grid.Row="5" Margin="0,8,0,14" Height="32" VerticalContentAlignment="Center" />

        <Grid Grid.Row="6" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="可用模型" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button x:Name="FetchModelsButton"
                    Grid.Column="1"
                    Width="110"
                    Height="30"
                    Click="FetchModelsButton_Click">获取模型</Button>
        </Grid>

        <TextBox x:Name="ModelSearchTextBox"
                 Grid.Row="7"
                 Margin="0,0,0,10"
                 Height="32"
                 VerticalContentAlignment="Center"
                 TextChanged="ModelSearchTextBox_TextChanged"
                 ToolTip="输入关键字过滤模型" />

        <TextBlock x:Name="ModelErrorTextBlock"
                   Grid.Row="8"
                   Margin="0,0,0,8"
                   Foreground="#DC2626"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <Border Grid.Row="9"
                Height="180"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Background="White"
                Padding="8">
            <ListBox x:Name="ModelListBox"
                     BorderThickness="0"
                     Background="Transparent"
                     FontFamily="Consolas"
                     FontSize="13"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
        </Border>

        <StackPanel Grid.Row="11"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="88" Height="32" Margin="0,0,8,0" IsDefault="True" Click="ConfirmButton_Click">确认</Button>
            <Button Width="88" Height="32" IsCancel="True" Click="CancelButton_Click">取消</Button>
        </StackPanel>
    </Grid>
</Window>
