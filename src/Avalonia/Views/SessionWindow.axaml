<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="APISwitch.Avalonia.Views.SessionWindow"
        Title="会话管理"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="CodexTabButton" Click="CodexTabButton_Click" Content="Codex" Width="120" Height="36" />
        <Button x:Name="ClaudeTabButton" Click="ClaudeTabButton_Click" Content="Claude Code" Width="120" Height="36" />
      </StackPanel>
      <TextBlock x:Name="SessionCountTextBlock" Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="#6B7280" />
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="320,12,*">
      <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="10">
        <Grid RowDefinitions="*,Auto">
          <ListBox x:Name="SessionListBox" SelectionChanged="SessionListBox_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Margin="2,4">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1" Text="{Binding FileSize}" Foreground="#6B7280" FontSize="11" />
                  <TextBlock Grid.Row="1" Text="{Binding RelativeTime}" Foreground="#6B7280" FontSize="12" Margin="0,4,0,0" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock x:Name="SessionEmptyTextBlock" Grid.Row="1" Text="暂无会话" Foreground="#9CA3AF" HorizontalAlignment="Center" IsVisible="False" Margin="0,8,0,0" />
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="14">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
          <TextBlock x:Name="SessionTitleTextBlock" Text="请选择左侧会话" FontSize="15" FontWeight="SemiBold" />
          <TextBlock x:Name="SessionProjectPathTextBlock" Grid.Row="1" Foreground="#2563EB" TextWrapping="Wrap" IsVisible="False" />
          <TextBox x:Name="MessagesTextBox" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
          <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="OpenProjectButton" Click="OpenProjectButton_Click" Content="打开目录" IsVisible="False" />
            <Button x:Name="DeleteSessionButton" Click="DeleteSessionButton_Click" Content="删除会话" IsVisible="False" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
