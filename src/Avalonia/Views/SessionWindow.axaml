<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:APISwitch.Avalonia.Views"
        x:Class="APISwitch.Avalonia.Views.SessionWindow"
        Title="会话管理"
        Icon="/Assets/app-preview.png"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
  <Window.Styles>
    <Style Selector="Button.tab-btn">
      <Setter Property="Height" Value="36" />
      <Setter Property="Width" Value="120" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D1D5DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="Button.path-link">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#2563EB" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="SelectableTextBlock.session-id">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#6B7280" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="MaxWidth" Value="280" />
    </Style>

  </Window.Styles>

  <Grid Margin="16" Background="#F3F4F6" RowDefinitions="Auto,*">
    <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="CodexTabButton" Classes="tab-btn" Click="CodexTabButton_Click" Content="Codex" />
        <Button x:Name="ClaudeTabButton" Classes="tab-btn" Click="ClaudeTabButton_Click" Content="Claude Code" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="300,12,*">
      <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock x:Name="SessionCountTextBlock"
                     Margin="14,12,14,10"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#374151"
                     Text="会话列表 (0)" />

          <Grid Grid.Row="1" Margin="10,0,10,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl x:Name="SessionGroupsItemsControl">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Expander IsExpanded="{Binding IsExpanded}" Margin="0,0,0,8">
                      <Expander.Header>
                        <TextBlock Text="{Binding GroupName}"
                                   Margin="2,4,2,2"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"
                                   TextTrimming="CharacterEllipsis" />
                      </Expander.Header>
                      <ListBox ItemsSource="{Binding Items}"
                               SelectionChanged="SessionGroupListBox_SelectionChanged">
                        <ListBox.ItemContainerTheme>
                          <ControlTheme TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="FocusAdorner" Value="{x:Null}" />
                            <Setter Property="Template">
                              <ControlTemplate>
                                <Border x:Name="ItemBorder"
                                        Padding="10"
                                        Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                  <ContentPresenter Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </Border>
                              </ControlTemplate>
                            </Setter>

                            <Style Selector="^:selected /template/ Border#ItemBorder">
                              <Setter Property="BorderBrush" Value="#2563EB" />
                              <Setter Property="BorderThickness" Value="2" />
                            </Style>
                          </ControlTheme>
                        </ListBox.ItemContainerTheme>
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                              <TextBlock Text="{Binding Title}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         Foreground="#111827"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Text="{Binding FileSize}"
                                         FontSize="11"
                                         Foreground="#6B7280" />
                              <TextBlock Grid.Row="1"
                                         Margin="0,6,0,0"
                                         Text="{Binding RelativeTime}"
                                         FontSize="12"
                                         Foreground="#6B7280" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Expander>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="SessionEmptyTextBlock"
                       Text="暂无会话"
                       FontSize="13"
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="False" />
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <Grid Margin="14,12,14,10" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock x:Name="SessionTitleTextBlock"
                         Text="请选择左侧会话"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#111827"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <SelectableTextBlock x:Name="SessionIdTextBlock"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   Classes="session-id"
                                   IsVisible="False" />
            </Grid>

            <Button x:Name="DeleteSessionButton"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Width="76"
                    Height="30"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="DeleteSessionButton_Click"
                    IsVisible="False"
                    Content="删除会话" />

            <Button x:Name="SessionProjectPathButton"
                    Grid.Row="1"
                    Classes="path-link"
                    Margin="0,6,0,0"
                    Click="SessionProjectPathButton_Click"
                    IsVisible="False" />
          </Grid>

          <ScrollViewer x:Name="MessagesScrollViewer"
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MessagesPanel" Margin="14,0,14,14" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
